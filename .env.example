# Banco local (docker compose). Producao: Supabase (pooler p/ web, direta p/ worker)
DATABASE_URL=postgresql://placarium:placarium@localhost:5432/placarium
DIRECT_DATABASE_URL=postgresql://placarium:placarium@localhost:5432/placarium

# Redis local (docker compose). Producao: Railway
REDIS_URL=redis://localhost:6379

# Provedor de dados esportivos (SPEC-004). NUNCA usar chave real fora de producao
FOOTBALL_PROVIDER=mock
FOOTBALL_API_KEY=

# IA (SPEC-010)
AI_API_KEY=

# Better Auth (SPEC-002)
BETTER_AUTH_SECRET=troque-por-um-segredo-real
NEXT_PUBLIC_APP_URL=http://localhost:3000
